# ATS Scorer Configuration Settings

# --- Server Configurations ---
PORT=5000
# In single-hosting production deployment, set CLIENT_URL to your subdomain:
# CLIENT_URL=https://atsscore.zyloconnect.com
CLIENT_URL=http://localhost:5173

# --- Anthropic AI (Claude) Configurations ---
# Required for resume analyses. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Stripe Billing Configurations ---
# Required for the $9 paywall. Get these keys from your Stripe dashboard: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PRICE_ID=price_your_price_id_here
STRIPE_CURRENCY=usd
STRIPE_PRICE_AMOUNT=900

# --- Operational Safety & Rate Limiting ---
# Rate Limit window size in milliseconds (e.g., 86400000 ms = 24 hours)
RATE_LIMIT_WINDOW_MS=86400000
# Maximum free requests allowed per IP inside the rate limit window
RATE_LIMIT_MAX=3
# Input text truncation length to control token cost and prevent prompt injection
INPUT_TRUNCATE_LIMIT=3000
